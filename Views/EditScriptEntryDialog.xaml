<Window x:Class="XuseExplorer.Views.EditScriptEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Script Entry"
        Width="650" Height="500"
        MinWidth="400" MinHeight="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16" Background="{StaticResource PrimaryBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Index (read-only) -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Index:" VerticalAlignment="Center" 
                   Margin="0,0,8,8" Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="IndexBox" IsReadOnly="True" 
                 Margin="0,0,0,8" Padding="6,4" FontFamily="Consolas"
                 Background="{StaticResource TertiaryBgBrush}" 
                 Foreground="{StaticResource TextSecondaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}"/>

        <!-- Seq ID (read-only) -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Seq ID:" VerticalAlignment="Center"
                   Margin="0,0,8,8" Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="SeqIdBox" IsReadOnly="True"
                 Margin="0,0,0,8" Padding="6,4" FontFamily="Consolas"
                 Background="{StaticResource TertiaryBgBrush}"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 BorderBrush="{StaticResource BorderBrush}"/>

        <!-- Voice -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Voice:" VerticalAlignment="Center"
                   Margin="0,0,8,8" Foreground="{StaticResource TextPrimaryBrush}"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="VoiceBox"
                 Margin="0,0,0,8" Padding="6,4" FontFamily="Consolas"
                 Background="{StaticResource SecondaryBgBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource AccentBrush}"/>

        <!-- Text label -->
        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Text="Text:" 
                   Margin="0,0,0,4" Foreground="{StaticResource TextPrimaryBrush}"/>

        <!-- Text editor (multiline) -->
        <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="TextBox"
                 AcceptsReturn="True" AcceptsTab="False"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 FontSize="13" FontFamily="Yu Gothic UI, Meiryo, MS Gothic, Consolas"
                 Padding="8,6"
                 Background="{StaticResource SecondaryBgBrush}"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="{StaticResource AccentBrush}"
                 Margin="0,0,0,12"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="90" Padding="8,6" Margin="0,0,8,0"
                    IsDefault="True" Click="OK_Click"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0"/>
            <Button Content="Cancel" Width="90" Padding="8,6"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
